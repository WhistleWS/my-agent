# ────────────────────────────────────────────────────────────────
# my-agent environment template. Copy to .env and fill in.
# ────────────────────────────────────────────────────────────────

# LLM endpoint. Defaults to the local CLIProxyAPI (CPA) running at
# http://localhost:8317 with an Anthropic-compatible /v1/messages route.
# To switch to the official Anthropic API later, change this to
# https://api.anthropic.com and set MY_AGENT_LLM_API_KEY to a real
# ANTHROPIC_API_KEY. No code changes required.
MY_AGENT_LLM_BASE_URL=http://localhost:8317

# API key. Use any entry from your CPA config.yaml `api-keys` list,
# or a real sk-ant-... key when pointing at the official API.
MY_AGENT_LLM_API_KEY=sk-replace-me

# Model identifier. Must exist in your CPA's merged model list.
# See http://localhost:8317/management.html for the live list.
MY_AGENT_MODEL=claude-sonnet-4-5-20250929

# Optional logging knobs.
# MY_AGENT_LOG_LEVEL=INFO
# MY_AGENT_DEBUG=1
